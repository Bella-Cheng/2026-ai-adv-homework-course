<div id="app">
  <section class="bg-bloom-cream">
    <div class="mx-auto grid max-w-[1440px] gap-12 px-4 py-12 sm:px-6 md:min-h-[640px] md:grid-cols-2 md:px-12 md:py-20 lg:gap-24 lg:px-24">
      <div class="hidden flex-col justify-center md:flex">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-bloom-brass">Member Access</p>
        <h1 class="font-serif-tc mt-4 text-[38px] font-semibold leading-tight text-bloom-green md:text-[48px]">
          登入 花漾生活
        </h1>
        <p class="mt-4 max-w-[500px] text-[18px] leading-7 text-bloom-muted">
          管理花禮收藏、預購通知與訂單紀錄。為喜歡的花束保留購買清單，快速回到購物車完成選購。
        </p>

        <div class="relative mt-10 h-[280px] max-w-[520px] overflow-hidden rounded-lg border border-bloom-line bg-bloom-photo shadow-[0_16px_34px_rgba(13,33,28,0.12),0_2px_8px_rgba(21,58,48,0.08)] sm:h-[360px] md:mt-12">
          <img
            src="/images/hero-yellow-flowers.jpg"
            alt="花藝商品展示"
            class="h-full w-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-bloom-green/75 via-bloom-green/35 to-transparent"></div>
          <div class="absolute bottom-10 left-8 right-8 text-bloom-ivory">
            <h2 class="font-serif-tc text-xl font-semibold">花藝商品 / 精選花禮收藏</h2>
            <p class="mt-3 max-w-[380px] text-[15px] leading-7 text-bloom-ivory/82">
              收藏本季花束、節慶花禮與訂閱商品，登入後可接續查看庫存、價格與配送狀態。
            </p>
            <div class="mt-6 h-px w-24 bg-bloom-brass"></div>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-center lg:justify-start">
        <div class="w-full max-w-[500px] rounded-lg border border-bloom-line bg-bloom-ivory p-5 shadow-[0_16px_34px_rgba(13,33,28,0.12),0_2px_8px_rgba(21,58,48,0.08)] sm:p-8 md:p-12">
          <template v-if="activeTab === 'login'">
            <h2 class="font-serif-tc text-[30px] font-semibold leading-tight text-bloom-ink">會員登入</h2>
            <p class="mt-3 text-[15px] leading-7 text-bloom-muted">
              使用信箱登入以查看購物車、商品收藏與到貨通知。
            </p>

            <form @submit.prevent="handleLogin" class="mt-8 space-y-4">
              <div>
                <input
                  v-model="loginForm.email"
                  type="email"
                  aria-label="Email address"
                  placeholder="Email address"
                  class="h-[58px] w-full rounded-lg border border-bloom-line bg-bloom-cream px-5 text-[15px] text-bloom-ink focus:border-bloom-brass focus:outline-none"
                  :class="{ 'border-red-400': errors.email }"
                />
                <p v-if="errors.email" class="mt-1 text-xs text-red-500">{{ errors.email }}</p>
              </div>

              <div>
                <input
                  v-model="loginForm.password"
                  type="password"
                  aria-label="Password"
                  placeholder="Password"
                  class="h-[58px] w-full rounded-lg border border-bloom-line bg-bloom-cream px-5 text-[15px] text-bloom-ink focus:border-bloom-brass focus:outline-none"
                  :class="{ 'border-red-400': errors.password }"
                />
                <p v-if="errors.password" class="mt-1 text-xs text-red-500">{{ errors.password }}</p>
              </div>

              <button
                type="submit"
                :disabled="submitting"
                class="h-[54px] w-full rounded-lg bg-bloom-brass text-sm font-semibold text-bloom-deep transition-colors hover:bg-[#D4B777] disabled:cursor-not-allowed disabled:opacity-50"
              >
                {{ submitting ? '登入中...' : '登入' }}
              </button>
            </form>

            <button
              type="button"
              @click="activeTab = 'register'; errors = {}"
              class="mt-4 h-[50px] w-full rounded-lg bg-bloom-green text-sm font-semibold text-bloom-ivory transition-colors hover:text-bloom-brass"
            >
              建立會員帳號
            </button>

            <p class="mt-5 text-sm text-bloom-muted">忘記密碼？｜需要協助請聯繫 Bloom Club</p>
          </template>

          <template v-else>
            <h2 class="font-serif-tc text-[30px] font-semibold leading-tight text-bloom-ink">建立會員帳號</h2>
            <p class="mt-3 text-[15px] leading-7 text-bloom-muted">
              建立帳號以保存喜愛商品、追蹤花禮訂單並接收預購提醒。
            </p>

            <form @submit.prevent="handleRegister" class="mt-8 space-y-4">
              <div>
                <input
                  v-model="registerForm.name"
                  type="text"
                  aria-label="姓名"
                  placeholder="姓名"
                  class="h-[58px] w-full rounded-lg border border-bloom-line bg-bloom-cream px-5 text-[15px] text-bloom-ink focus:border-bloom-brass focus:outline-none"
                  :class="{ 'border-red-400': errors.name }"
                />
                <p v-if="errors.name" class="mt-1 text-xs text-red-500">{{ errors.name }}</p>
              </div>

              <div>
                <input
                  v-model="registerForm.email"
                  type="email"
                  aria-label="Email address"
                  placeholder="Email address"
                  class="h-[58px] w-full rounded-lg border border-bloom-line bg-bloom-cream px-5 text-[15px] text-bloom-ink focus:border-bloom-brass focus:outline-none"
                  :class="{ 'border-red-400': errors.email }"
                />
                <p v-if="errors.email" class="mt-1 text-xs text-red-500">{{ errors.email }}</p>
              </div>

              <div>
                <input
                  v-model="registerForm.password"
                  type="password"
                  aria-label="Password"
                  placeholder="Password"
                  class="h-[58px] w-full rounded-lg border border-bloom-line bg-bloom-cream px-5 text-[15px] text-bloom-ink focus:border-bloom-brass focus:outline-none"
                  :class="{ 'border-red-400': errors.password }"
                />
                <p v-if="errors.password" class="mt-1 text-xs text-red-500">{{ errors.password }}</p>
              </div>

              <button
                type="submit"
                :disabled="submitting"
                class="h-[54px] w-full rounded-lg bg-bloom-brass text-sm font-semibold text-bloom-deep transition-colors hover:bg-[#D4B777] disabled:cursor-not-allowed disabled:opacity-50"
              >
                {{ submitting ? '註冊中...' : '建立帳號' }}
              </button>
            </form>

            <button
              type="button"
              @click="activeTab = 'login'; errors = {}"
              class="mt-4 h-[50px] w-full rounded-lg bg-bloom-green text-sm font-semibold text-bloom-ivory transition-colors hover:text-bloom-brass"
            >
              返回會員登入
            </button>

            <p class="mt-5 text-sm text-bloom-muted">註冊後即可同步購物車並管理花禮訂單。</p>
          </template>
        </div>
      </div>
    </div>
  </section>
</div>
