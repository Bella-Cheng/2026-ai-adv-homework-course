<div id="app">
  <div class="mx-auto max-w-[1088px]">
    <div class="flex items-start justify-between gap-6">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-bloom-brass">Admin Orders</p>
        <h1 class="font-serif-tc mt-2 text-[38px] font-semibold leading-[44px] text-bloom-green">訂單管理</h1>
        <p class="mt-4 max-w-[680px] text-[15px] leading-6 text-bloom-muted">
          查看訂單列表與訂單明細，依 status 篩選 pending、paid、failed，付款狀態清楚標示。
        </p>
      </div>
    </div>

    <div class="mt-10 grid gap-7 md:grid-cols-4">
      <article class="rounded-lg border border-bloom-line bg-bloom-ivory p-6 shadow-[0_8px_24px_rgba(13,20,15,0.10),0_2px_6px_rgba(13,20,15,0.04)]">
        <p class="text-[13px] text-bloom-muted">今日訂單</p>
        <div class="mt-2 flex items-end justify-between">
          <p class="text-[30px] font-semibold leading-[34px] text-bloom-green">{{ orders.length || pagination.total }}</p>
          <p class="pb-1 text-right text-xs font-medium text-bloom-brass">待處理 {{ pendingCount }}</p>
        </div>
      </article>
      <article class="rounded-lg border border-bloom-line bg-bloom-ivory p-6 shadow-[0_8px_24px_rgba(13,20,15,0.10),0_2px_6px_rgba(13,20,15,0.04)]">
        <p class="text-[13px] text-bloom-muted">已付款</p>
        <div class="mt-2 flex items-end justify-between">
          <p class="text-[30px] font-semibold leading-[34px] text-bloom-green">{{ paidCount }}</p>
          <p class="pb-1 text-right text-xs font-medium text-bloom-brass">paid</p>
        </div>
      </article>
      <article class="rounded-lg border border-bloom-line bg-bloom-ivory p-6 shadow-[0_8px_24px_rgba(13,20,15,0.10),0_2px_6px_rgba(13,20,15,0.04)]">
        <p class="text-[13px] text-bloom-muted">付款失敗</p>
        <div class="mt-2 flex items-end justify-between">
          <p class="text-[30px] font-semibold leading-[34px] text-bloom-green">{{ failedCount }}</p>
          <p class="pb-1 text-right text-xs font-medium text-bloom-brass">failed</p>
        </div>
      </article>
      <article class="rounded-lg border border-bloom-line bg-bloom-ivory p-6 shadow-[0_8px_24px_rgba(13,20,15,0.10),0_2px_6px_rgba(13,20,15,0.04)]">
        <p class="text-[13px] text-bloom-muted">營收估計</p>
        <div class="mt-2 flex items-end justify-between">
          <p class="text-[30px] font-semibold leading-[34px] text-bloom-green">{{ revenueText }}</p>
          <p class="pb-1 text-right text-xs font-medium text-bloom-brass">NTD</p>
        </div>
      </article>
    </div>

    <div class="mt-10 flex min-h-[76px] flex-wrap items-center gap-4 rounded-lg border border-bloom-line bg-bloom-ivory px-6 py-5 shadow-[0_8px_24px_rgba(13,20,15,0.10),0_2px_6px_rgba(13,20,15,0.04)]">
      <p class="mr-auto text-[13px] text-bloom-muted">篩選付款狀態</p>
      <button type="button" @click="statusFilter = ''" class="rounded-full px-5 py-1.5 text-xs font-medium" :class="statusFilter === '' ? 'bg-bloom-green text-bloom-ivory' : 'bg-bloom-photo text-bloom-deep'">全部</button>
      <button type="button" @click="statusFilter = 'pending'" class="rounded-full px-5 py-1.5 text-xs font-medium" :class="statusFilter === 'pending' ? 'bg-bloom-green text-bloom-ivory' : 'bg-bloom-photo text-bloom-deep'">pending</button>
      <button type="button" @click="statusFilter = 'paid'" class="rounded-full px-5 py-1.5 text-xs font-medium" :class="statusFilter === 'paid' ? 'bg-bloom-green text-bloom-ivory' : 'bg-bloom-sage text-bloom-deep'">paid</button>
      <button type="button" @click="statusFilter = 'failed'" class="rounded-full px-5 py-1.5 text-xs font-medium" :class="statusFilter === 'failed' ? 'bg-bloom-green text-bloom-ivory' : 'bg-bloom-blush text-bloom-deep'">failed</button>
    </div>

    <div v-if="loading" class="flex justify-center py-16">
      <div class="h-8 w-8 animate-spin rounded-full border-4 border-bloom-brass border-t-transparent"></div>
    </div>

    <template v-else>
      <div class="mt-8 overflow-hidden rounded-lg">
        <table class="w-full text-sm">
          <thead>
            <tr class="h-[52px] bg-bloom-green text-left text-xs font-semibold text-bloom-ivory">
              <th class="px-6 font-semibold">訂單編號</th>
              <th class="px-6 font-semibold">顧客</th>
              <th class="px-6 font-semibold">金額</th>
              <th class="px-6 font-semibold">訂單狀態</th>
              <th class="px-6 font-semibold">付款狀態</th>
              <th class="px-6 text-right font-semibold">操作</th>
            </tr>
          </thead>
          <tbody>
            <tr
              v-for="order in orders"
              :key="order.id"
              class="h-[72px] cursor-pointer border border-bloom-line bg-bloom-ivory"
              @click="viewDetail(order.id)"
            >
              <td class="px-6 font-semibold text-bloom-ink">{{ order.order_no }}</td>
              <td class="px-6 text-[13px] text-bloom-ink">{{ order.recipient_name }}</td>
              <td class="px-6 text-[13px] font-medium text-bloom-green">NT$ {{ order.total_amount.toLocaleString() }}</td>
              <td class="px-6">
                <span class="inline-flex h-7 min-w-[86px] items-center justify-center rounded-full px-4 text-xs font-medium text-bloom-deep" :class="statusMap[order.status]?.cls || 'bg-bloom-photo'">
                  {{ statusMap[order.status]?.label || order.status }}
                </span>
              </td>
              <td class="px-6">
                <span class="inline-flex h-7 min-w-[100px] items-center justify-center rounded-full px-4 text-xs font-medium text-bloom-deep" :class="statusMap[order.status]?.cls || 'bg-bloom-photo'">
                  {{ order.status }}
                </span>
              </td>
              <td class="px-6 text-right">
                <button type="button" class="text-[13px] font-medium text-bloom-green hover:text-bloom-brass">查看明細</button>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div v-if="pagination.totalPages > 1" class="mt-6 flex justify-center gap-2">
        <button
          v-for="p in pagination.totalPages"
          :key="p"
          @click="loadOrders(p)"
          class="h-10 w-10 rounded-lg text-sm transition-colors"
          :class="p === pagination.page ? 'bg-bloom-brass text-bloom-deep' : 'bg-bloom-ivory text-bloom-muted hover:text-bloom-green'"
        >
          {{ p }}
        </button>
      </div>
    </template>

    <div class="mt-8 flex items-center justify-between gap-6 rounded-lg border border-bloom-line bg-bloom-ivory px-6 py-5 shadow-[0_8px_24px_rgba(13,20,15,0.10),0_2px_6px_rgba(13,20,15,0.04)]">
      <div>
        <h2 class="font-serif-tc text-base font-semibold text-bloom-green">訂單明細預覽</h2>
        <p class="mt-2 text-[13px] leading-5 text-bloom-muted">
          點選「查看明細」後呈現收件資料、商品清單、付款 provider、merchant_trade_no 與 payment_status。
        </p>
      </div>
      <p class="max-w-[250px] text-right text-xs leading-5 text-bloom-muted">
        管理者可確認花禮品項、數量、收件資料與付款狀態，協助安排出貨。
      </p>
    </div>
  </div>

  <div v-if="detailVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/40" @click="detailVisible = false"></div>
    <div class="relative mx-4 max-h-[80vh] w-full max-w-2xl overflow-y-auto rounded-lg border border-bloom-line bg-bloom-ivory p-6 shadow-xl">
      <div v-if="detailLoading" class="flex justify-center py-8">
        <div class="h-8 w-8 animate-spin rounded-full border-4 border-bloom-brass border-t-transparent"></div>
      </div>
      <template v-else-if="detailOrder">
        <div class="mb-4 flex items-start justify-between">
          <div>
            <h3 class="font-serif-tc text-lg font-semibold text-bloom-green">訂單詳情</h3>
            <p class="mt-1 text-sm text-bloom-muted">確認花禮商品、收件資料與付款狀態。</p>
          </div>
          <button @click="detailVisible = false" class="text-lg text-bloom-muted hover:text-bloom-green">&times;</button>
        </div>

        <div class="space-y-4 text-sm">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-bloom-muted">訂單編號</p>
              <p class="text-bloom-ink">{{ detailOrder.order_no }}</p>
            </div>
            <div>
              <p class="text-bloom-muted">狀態</p>
              <span class="mt-1 inline-flex rounded-full px-3 py-1 text-xs text-bloom-deep" :class="statusMap[detailOrder.status]?.cls || 'bg-bloom-photo'">
                {{ statusMap[detailOrder.status]?.label || detailOrder.status }}
              </span>
            </div>
            <div>
              <p class="text-bloom-muted">買家</p>
              <p class="text-bloom-ink">{{ detailOrder.user?.name }} ({{ detailOrder.user?.email }})</p>
            </div>
            <div>
              <p class="text-bloom-muted">日期</p>
              <p class="text-bloom-ink">{{ new Date(detailOrder.created_at).toLocaleDateString('zh-TW') }}</p>
            </div>
          </div>

          <div class="border-t border-bloom-line pt-4">
            <p class="mb-2 text-bloom-muted">收件資訊</p>
            <p class="text-bloom-ink">{{ detailOrder.recipient_name }}</p>
            <p class="text-bloom-muted">{{ detailOrder.recipient_email }}</p>
            <p class="text-bloom-muted">{{ detailOrder.recipient_address }}</p>
          </div>

          <div class="border-t border-bloom-line pt-4">
            <p class="mb-2 text-bloom-muted">商品明細</p>
            <table class="w-full">
              <thead>
                <tr class="border-b border-bloom-line text-bloom-muted">
                  <th class="py-2 text-left font-normal">商品名稱</th>
                  <th class="py-2 text-right font-normal">單價</th>
                  <th class="py-2 text-right font-normal">數量</th>
                  <th class="py-2 text-right font-normal">小計</th>
                </tr>
              </thead>
              <tbody>
                <tr v-for="item in detailOrder.items" :key="item.id" class="border-b border-bloom-line">
                  <td class="py-2 text-bloom-ink">{{ item.product_name }}</td>
                  <td class="py-2 text-right">NT$ {{ item.product_price.toLocaleString() }}</td>
                  <td class="py-2 text-right">{{ item.quantity }}</td>
                  <td class="py-2 text-right font-medium">NT$ {{ (item.product_price * item.quantity).toLocaleString() }}</td>
                </tr>
              </tbody>
            </table>
            <div class="mt-3 flex justify-end border-t border-bloom-line pt-2">
              <span class="text-lg font-bold text-bloom-brass">總計 NT$ {{ detailOrder.total_amount.toLocaleString() }}</span>
            </div>
          </div>
        </div>
      </template>
    </div>
  </div>
</div>
