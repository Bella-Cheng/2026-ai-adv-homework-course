<div id="app">
  <div class="mx-auto max-w-[1088px]">
    <div class="flex items-start justify-between gap-6">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-bloom-brass">Admin Products</p>
        <h1 class="font-serif-tc mt-2 text-[38px] font-semibold leading-[44px] text-bloom-green">商品管理</h1>
        <p class="mt-4 max-w-[620px] text-[15px] leading-6 text-bloom-muted">
          管理現有花藝商品資料，可新增、編輯、刪除商品，並快速查看價格與庫存狀態。
        </p>
      </div>
      <button
        @click="openCreate"
        class="mt-8 h-[42px] w-[146px] rounded bg-bloom-brass text-[13px] font-semibold text-bloom-deep transition-colors hover:bg-[#D4B777]"
      >
        新增商品
      </button>
    </div>

    <div class="mt-10 grid gap-7 md:grid-cols-4">
      <article class="rounded-lg border border-bloom-line bg-bloom-ivory p-6 shadow-[0_8px_24px_rgba(13,20,15,0.10),0_2px_6px_rgba(13,20,15,0.04)]">
        <p class="text-[13px] text-bloom-muted">商品總數</p>
        <div class="mt-2 flex items-end justify-between">
          <p class="text-[30px] font-semibold leading-[34px] text-bloom-green">{{ products.length || pagination.total }}</p>
          <p class="pb-1 text-right text-xs font-medium text-bloom-brass">依現有資料</p>
        </div>
      </article>
      <article class="rounded-lg border border-bloom-line bg-bloom-ivory p-6 shadow-[0_8px_24px_rgba(13,20,15,0.10),0_2px_6px_rgba(13,20,15,0.04)]">
        <p class="text-[13px] text-bloom-muted">本季熱賣</p>
        <div class="mt-2 flex items-end justify-between">
          <p class="text-[30px] font-semibold leading-[34px] text-bloom-green">{{ Math.min(products.length, 4) }}</p>
          <p class="pb-1 text-right text-xs font-medium text-bloom-brass">夏季花束</p>
        </div>
      </article>
      <article class="rounded-lg border border-bloom-line bg-bloom-ivory p-6 shadow-[0_8px_24px_rgba(13,20,15,0.10),0_2px_6px_rgba(13,20,15,0.04)]">
        <p class="text-[13px] text-bloom-muted">低庫存提醒</p>
        <div class="mt-2 flex items-end justify-between">
          <p class="text-[30px] font-semibold leading-[34px] text-bloom-green">{{ lowStockCount }}</p>
          <p class="pb-1 text-right text-xs font-medium text-bloom-brass">需補貨</p>
        </div>
      </article>
      <article class="rounded-lg border border-bloom-line bg-bloom-ivory p-6 shadow-[0_8px_24px_rgba(13,20,15,0.10),0_2px_6px_rgba(13,20,15,0.04)]">
        <p class="text-[13px] text-bloom-muted">下季預購</p>
        <div class="mt-2 flex items-end justify-between">
          <p class="text-[30px] font-semibold leading-[34px] text-bloom-green">2</p>
          <p class="pb-1 text-right text-xs font-medium text-bloom-brass">秋季規劃</p>
        </div>
      </article>
    </div>

    <div class="mt-10 flex min-h-[76px] flex-wrap items-center gap-4 rounded-lg border border-bloom-line bg-bloom-ivory px-6 py-5 shadow-[0_8px_24px_rgba(13,20,15,0.10),0_2px_6px_rgba(13,20,15,0.04)]">
      <p class="mr-auto text-[13px] text-bloom-muted">篩選上架狀態</p>
      <span class="rounded-full bg-bloom-green px-5 py-1.5 text-xs font-medium text-bloom-ivory">全部</span>
      <span class="rounded-full bg-bloom-photo px-5 py-1.5 text-xs font-medium text-bloom-deep">上架中</span>
      <span class="rounded-full bg-bloom-blush px-5 py-1.5 text-xs font-medium text-bloom-deep">低庫存</span>
      <span class="rounded-full bg-bloom-sage px-5 py-1.5 text-xs font-medium text-bloom-deep">季節限定</span>
    </div>

    <div v-if="loading" class="flex justify-center py-16">
      <div class="h-8 w-8 animate-spin rounded-full border-4 border-bloom-brass border-t-transparent"></div>
    </div>

    <template v-else>
      <div class="mt-8 overflow-hidden rounded-lg">
        <table class="w-full text-sm">
          <thead>
            <tr class="h-[52px] bg-bloom-green text-left text-xs font-semibold text-bloom-ivory">
              <th class="px-6 font-semibold">商品</th>
              <th class="px-6 font-semibold">價格</th>
              <th class="px-6 font-semibold">庫存</th>
              <th class="px-6 font-semibold">狀態</th>
              <th class="px-6 text-right font-semibold">操作</th>
            </tr>
          </thead>
          <tbody>
            <tr v-for="(product, index) in products" :key="product.id" class="h-[68px] border border-bloom-line bg-bloom-ivory">
              <td class="px-6">
                <div class="flex items-center gap-5">
                  <img
                    :src="imageFor(product)"
                    :alt="product.name"
                    class="h-10 w-10 rounded-lg border border-bloom-line bg-bloom-photo object-cover"
                  />
                  <div>
                    <p class="font-semibold text-bloom-ink">{{ product.name }}</p>
                    <p class="mt-1 text-xs text-bloom-muted">{{ productSubtitle(product, index) }}</p>
                  </div>
                </div>
              </td>
              <td class="px-6 text-[13px] font-medium text-bloom-green">NT$ {{ product.price.toLocaleString() }}</td>
              <td class="px-6 text-[13px] text-bloom-ink">{{ product.stock }}</td>
              <td class="px-6">
                <span class="inline-flex h-7 min-w-[84px] items-center justify-center rounded-full px-4 text-xs font-medium text-bloom-deep" :class="product.stock <= 5 ? 'bg-bloom-blush' : 'bg-bloom-sage'">
                  {{ product.stock <= 5 ? '低庫存' : '上架中' }}
                </span>
              </td>
              <td class="px-6 text-right">
                <button @click="openEdit(product)" class="text-[13px] font-medium text-bloom-green hover:text-bloom-brass">編輯</button>
                <button @click="confirmDeleteFn(product.id)" class="ml-6 text-[13px] font-medium text-bloom-green hover:text-red-600">刪除</button>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div v-if="pagination.totalPages > 1" class="mt-6 flex justify-center gap-2">
        <button
          v-for="p in pagination.totalPages"
          :key="p"
          @click="loadProducts(p)"
          class="h-10 w-10 rounded-lg text-sm transition-colors"
          :class="p === pagination.page ? 'bg-bloom-brass text-bloom-deep' : 'bg-bloom-ivory text-bloom-muted hover:text-bloom-green'"
        >
          {{ p }}
        </button>
      </div>
    </template>

    <div class="mt-8 rounded-lg border border-bloom-line bg-bloom-ivory px-6 py-4">
      <p class="text-xs leading-[18px] text-bloom-muted">
        商品資料會同步顯示於前台商品卡片，請確認花束名稱、商品描述、價格、庫存與圖片 URL 皆可協助使用者完成選購。
      </p>
    </div>
  </div>

  <div v-if="modalVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/40" @click="modalVisible = false"></div>
    <div class="relative mx-4 w-full max-w-lg rounded-lg border border-bloom-line bg-bloom-ivory p-6 shadow-xl">
      <h3 class="font-serif-tc text-lg font-semibold text-bloom-green">
        {{ editingProduct ? '編輯商品' : '新增商品' }}
      </h3>
      <p class="mt-2 text-sm text-bloom-muted">補齊商品名稱、描述、價格、庫存與圖片，讓前台花禮卡片資訊清楚完整。</p>
      <form @submit.prevent="handleSave" class="mt-5 space-y-4">
        <div>
          <label class="mb-1 block text-sm text-bloom-muted">商品名稱 *</label>
          <input v-model="form.name" type="text" class="w-full rounded-lg border border-bloom-line bg-bloom-cream px-3 py-2 text-sm focus:border-bloom-brass focus:outline-none" />
        </div>
        <div>
          <label class="mb-1 block text-sm text-bloom-muted">商品描述</label>
          <textarea v-model="form.description" rows="3" class="w-full rounded-lg border border-bloom-line bg-bloom-cream px-3 py-2 text-sm focus:border-bloom-brass focus:outline-none"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="mb-1 block text-sm text-bloom-muted">價格 *</label>
            <input v-model.number="form.price" type="number" min="1" class="w-full rounded-lg border border-bloom-line bg-bloom-cream px-3 py-2 text-sm focus:border-bloom-brass focus:outline-none" />
          </div>
          <div>
            <label class="mb-1 block text-sm text-bloom-muted">庫存 *</label>
            <input v-model.number="form.stock" type="number" min="0" class="w-full rounded-lg border border-bloom-line bg-bloom-cream px-3 py-2 text-sm focus:border-bloom-brass focus:outline-none" />
          </div>
        </div>
        <div>
          <label class="mb-1 block text-sm text-bloom-muted">圖片 URL</label>
          <input v-model="form.image_url" type="text" class="w-full rounded-lg border border-bloom-line bg-bloom-cream px-3 py-2 text-sm focus:border-bloom-brass focus:outline-none" />
        </div>
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" @click="modalVisible = false" class="rounded-lg border border-bloom-line px-4 py-2 text-sm text-bloom-muted hover:text-bloom-green">取消</button>
          <button type="submit" :disabled="saving" class="rounded-lg bg-bloom-brass px-4 py-2 text-sm font-semibold text-bloom-deep hover:bg-[#D4B777] disabled:opacity-50">
            {{ saving ? '儲存中...' : '儲存' }}
          </button>
        </div>
      </form>
    </div>
  </div>

  <div v-if="confirmVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/40" @click="confirmVisible = false"></div>
    <div class="relative mx-4 w-full max-w-sm rounded-lg border border-bloom-line bg-bloom-ivory p-6 text-center shadow-xl">
      <h3 class="font-serif-tc text-lg font-semibold text-bloom-green">確認刪除</h3>
      <p class="mb-6 mt-2 text-sm text-bloom-muted">確定要刪除這個花藝商品嗎？刪除後前台商品卡片將不再顯示。</p>
      <div class="flex justify-center gap-3">
        <button @click="confirmVisible = false" class="rounded-lg border border-bloom-line px-4 py-2 text-sm text-bloom-muted hover:text-bloom-green">取消</button>
        <button @click="handleDelete" class="rounded-lg bg-red-500 px-4 py-2 text-sm font-semibold text-white hover:bg-red-600">確認刪除</button>
      </div>
    </div>
  </div>
</div>
