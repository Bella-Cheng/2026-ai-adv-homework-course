<div id="app">
  <section class="mx-auto max-w-[1440px] px-4 py-10 sm:px-6 md:px-12 lg:px-24 lg:py-12">
    <div class="grid gap-8 lg:grid-cols-[1fr_388px] lg:items-start">
      <div>
        <h1 class="font-serif-tc text-[34px] font-bold leading-[44px] text-bloom-green">我的訂單</h1>
        <p class="mt-4 text-[15px] leading-6 text-bloom-muted">
          查看花禮訂單編號、建立日期、付款狀態與訂單總額。
        </p>
      </div>

      <aside class="rounded-lg bg-bloom-green p-7 text-bloom-ivory shadow-[0_16px_34px_rgba(13,33,28,0.10),0_2px_8px_rgba(21,58,48,0.06)]">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="font-serif-tc text-xl font-semibold">訂單總覽</h2>
            <p class="mt-2 text-[13px] leading-5 text-bloom-ivory/70">彙整近期花禮訂單與付款進度。</p>
          </div>
          <p class="font-serif-tc text-2xl font-semibold text-bloom-brass">{{ orderCount }} 筆訂單</p>
        </div>
      </aside>
    </div>

    <div v-if="loading" class="flex justify-center py-16">
      <div class="h-8 w-8 animate-spin rounded-full border-4 border-bloom-brass border-t-transparent"></div>
    </div>

    <template v-else>
      <div class="mt-12">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-bloom-brass">Order List</p>
        <h2 class="font-serif-tc mt-4 text-[26px] font-semibold leading-9 text-bloom-green">訂單列表</h2>
      </div>

      <div v-if="orders.length === 0" class="mt-7 rounded-lg border border-bloom-line bg-bloom-ivory p-8 shadow-[0_16px_34px_rgba(13,33,28,0.10),0_2px_8px_rgba(21,58,48,0.06)]">
        <div class="flex flex-col gap-5 sm:flex-row sm:items-center">
          <div class="min-w-0 flex-1">
            <h3 class="font-serif-tc text-[22px] font-semibold leading-8 text-bloom-green">尚無訂單</h3>
            <p class="mt-1 text-sm leading-6 text-bloom-muted">目前還沒有花禮訂單，先挑選一束適合今日心意的花束吧。</p>
          </div>
          <a href="/#products" class="inline-flex h-10 shrink-0 items-center justify-center rounded-lg bg-bloom-brass px-8 text-sm font-semibold text-bloom-deep transition-colors hover:bg-[#D4B777]">
            去逛逛
          </a>
        </div>
      </div>

      <div v-else class="mt-7 space-y-6">
        <a
          v-for="(order, index) in orders"
          :key="order.id"
          :href="'/orders/' + order.id"
          class="group flex min-h-[120px] flex-col items-start gap-5 rounded-lg border border-bloom-line bg-bloom-ivory p-5 shadow-[0_16px_34px_rgba(13,33,28,0.10),0_2px_8px_rgba(21,58,48,0.06)] transition-shadow hover:shadow-[0_20px_38px_rgba(13,33,28,0.14),0_3px_10px_rgba(21,58,48,0.08)] sm:flex-row sm:items-center"
        >
          <img
            src="/images/hero-yellow-flowers.jpg"
            alt="花漾生活花禮訂單"
            class="h-20 w-20 shrink-0 rounded-lg border border-bloom-line bg-bloom-photo object-cover"
          />

          <div class="min-w-0 flex-1">
            <p class="text-sm leading-5 text-bloom-muted">訂單編號：{{ order.order_no }}</p>
            <p class="mt-2 text-xs leading-4 text-bloom-muted/80">{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
            <p class="mt-3 text-xs leading-4 text-bloom-green">{{ orderSummaryText(index) }}</p>
          </div>

          <div class="flex w-full flex-wrap items-center justify-between gap-4 sm:w-auto sm:shrink-0 sm:justify-start sm:gap-8">
            <span class="font-serif-tc text-[22px] font-semibold leading-8 text-bloom-ink">
              NT$ {{ order.total_amount.toLocaleString() }}
            </span>
            <span
              class="inline-flex h-[30px] min-w-[84px] items-center justify-center rounded-full px-4 text-xs font-medium"
              :class="statusMap[order.status]?.cls || 'bg-bloom-cream text-bloom-muted'"
            >
              {{ statusMap[order.status]?.label || order.status }}
            </span>
            <span class="text-2xl leading-none text-bloom-muted transition-colors group-hover:text-bloom-brass">→</span>
          </div>
        </a>
      </div>

      <div class="mt-12">
        <section class="rounded-lg border border-bloom-line bg-bloom-ivory p-8 shadow-[0_16px_34px_rgba(13,33,28,0.10),0_2px_8px_rgba(21,58,48,0.06)]">
          <h2 class="font-serif-tc text-[22px] font-semibold leading-8 text-bloom-green">花禮提醒</h2>
          <p class="mt-4 text-sm leading-7 text-bloom-muted">
            待付款訂單可進入訂單詳情重新前往綠界付款；付款完成後，花漾生活會依訂單資訊安排後續配送。
          </p>
        </section>
      </div>
    </template>
  </section>
</div>
