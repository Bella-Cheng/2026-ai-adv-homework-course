<div id="app" data-product-id="<%= productId %>">
  <div v-if="loading" class="flex justify-center py-16">
    <div class="h-8 w-8 animate-spin rounded-full border-4 border-bloom-brass border-t-transparent"></div>
  </div>

  <div v-else-if="notFound" class="py-20 text-center">
    <h2 class="font-serif-tc text-xl font-semibold text-bloom-green">找不到此商品</h2>
    <p class="mt-2 text-sm text-bloom-muted">商品可能已下架，請回到花藝商品列表重新挑選。</p>
    <a href="/" class="mt-6 inline-flex h-12 items-center justify-center rounded bg-bloom-brass px-6 text-sm font-semibold text-bloom-deep">回到首頁</a>
  </div>

  <template v-else-if="product">
    <div class="bg-bloom-ivory">
      <div class="mx-auto max-w-[1440px] px-6 py-6 md:px-24">
        <nav class="flex flex-wrap items-center gap-2 text-[13px] text-bloom-muted" aria-label="麵包屑">
          <a href="/" class="cursor-pointer transition-colors hover:text-bloom-brass">首頁</a>
          <span>/</span>
          <a href="/#products" class="cursor-pointer transition-colors hover:text-bloom-brass">所有花藝商品</a>
          <span>/</span>
          <span class="cursor-pointer transition-colors hover:text-bloom-brass">{{ product.name }}</span>
        </nav>
      </div>
    </div>

    <section class="mx-auto grid max-w-[1440px] gap-14 px-6 py-[70px] md:grid-cols-[610px_1fr] md:px-24">
      <div>
        <div class="h-[650px] overflow-hidden rounded-lg border border-bloom-line bg-bloom-photo">
          <img :src="imageFor(product)" :alt="product.name" class="h-full w-full object-cover" />
        </div>

        <div class="mt-8 flex gap-6">
          <button
            v-for="index in 4"
            :key="index"
            type="button"
            class="h-[88px] w-[88px] overflow-hidden rounded-lg border border-bloom-line bg-bloom-photo"
          >
            <img :src="imageFor(product)" :alt="product.name + ' 商品縮圖 ' + index" class="h-full w-full object-cover" />
          </button>
        </div>
      </div>

      <div class="pt-1">
        <span class="inline-flex h-7 items-center rounded-full bg-bloom-brass px-5 text-xs font-medium text-bloom-deep">本季熱賣</span>
        <h1 class="font-serif-tc mt-7 text-[48px] font-semibold leading-[56px] text-bloom-green">
          {{ product.name }}
        </h1>
        <p class="mt-3 text-[15px] leading-[22px] text-bloom-muted">{{ productSubtitle }}</p>
        <p class="mt-10 max-w-[480px] text-base leading-7 text-bloom-ink">
          {{ product.description || productCopy }}
        </p>

        <div class="mt-9 flex items-center gap-10">
          <p class="text-[30px] font-semibold leading-[34px] text-bloom-green">NT$ {{ product.price.toLocaleString() }}</p>
          <p class="text-[13px] text-bloom-muted">庫存 {{ product.stock }} 件</p>
        </div>

        <div class="mt-10 flex h-12 w-[164px] items-center justify-between rounded border border-bloom-line bg-bloom-ivory px-8 text-[15px] font-semibold text-bloom-green">
          <button type="button" @click="decrease" class="hover:text-bloom-brass">-</button>
          <span>{{ quantity }}</span>
          <button type="button" @click="increase" class="hover:text-bloom-brass">+</button>
        </div>

        <div class="mt-9 flex flex-wrap gap-6">
          <button
            @click="addToCart"
            :disabled="adding || product.stock <= 0"
            class="h-12 w-[188px] rounded bg-bloom-green text-[13px] font-semibold text-bloom-ivory transition-colors hover:text-bloom-brass disabled:cursor-not-allowed disabled:opacity-50"
          >
            {{ product.stock <= 0 ? '已售完' : '加入購物車' }}
          </button>
          <button
            @click="buyNow"
            :disabled="adding || product.stock <= 0"
            class="h-12 w-[168px] rounded bg-bloom-brass text-[13px] font-semibold text-bloom-deep transition-colors hover:bg-[#D4B777] disabled:cursor-not-allowed disabled:opacity-50"
          >
            直接結帳
          </button>
        </div>

        <div class="mt-12 max-w-[478px] rounded-lg border border-bloom-line bg-bloom-ivory p-6">
          <h2 class="font-serif-tc text-base font-semibold text-bloom-green">花禮資訊</h2>
          <div class="mt-3 text-[13px] leading-[22px] text-bloom-muted">
            <p>配送：台灣本島配送</p>
            <p>包裝：花漾生活季節包裝紙與緞帶</p>
            <p>保存：收到後修剪花腳並每日換水</p>
            <p>狀態：當季限定，可加入購物車</p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-bloom-ivory">
      <div class="mx-auto flex max-w-[1440px] flex-col gap-8 px-6 py-16 md:flex-row md:items-center md:px-24">
        <h2 class="font-serif-tc text-[28px] font-semibold leading-[34px] text-bloom-green">你可能也喜歡</h2>
        <p class="text-[15px] leading-[22px] text-bloom-ink">白色百合花禮盒　　繽紛向日葵花束　　季節鮮花訂閱（月配）</p>
      </div>
    </section>
  </template>
</div>
