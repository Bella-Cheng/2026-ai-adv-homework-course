<div id="app">
  <section class="mx-auto max-w-[1440px] px-4 py-10 sm:px-6 md:px-12 lg:px-24 lg:py-12">
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-bloom-brass">Summer Bouquet Cart</p>
    <h1 class="font-serif-tc mt-4 text-[34px] font-bold leading-[46px] text-bloom-ink md:text-[44px] md:leading-[64px]">購物車花禮明細</h1>
    <p class="mt-2 max-w-[620px] text-base leading-[23px] text-bloom-muted">
      確認本季花束、配送與花禮卡片，下一步前往結帳完成付款。
    </p>

    <div v-if="loading" class="flex justify-center py-16">
      <div class="h-8 w-8 animate-spin rounded-full border-4 border-bloom-brass border-t-transparent"></div>
    </div>

    <div v-else-if="items.length === 0" class="mt-12 rounded-lg border border-bloom-line bg-bloom-ivory px-6 py-16 text-center shadow-[0_18px_34px_rgba(13,33,28,0.08),0_4px_8px_rgba(13,33,28,0.04)]">
      <h2 class="font-serif-tc text-2xl font-semibold text-bloom-green">購物車是空的</h2>
      <p class="mt-3 text-sm text-bloom-muted">挑選一束適合今日心意的花禮，加入購物車後即可安排收件與付款。</p>
      <a href="/#products" class="mt-6 inline-flex h-12 items-center justify-center rounded-lg bg-bloom-brass px-7 text-sm font-semibold text-bloom-deep hover:bg-[#D4B777]">去逛逛</a>
    </div>

    <template v-else>
      <div class="mt-12 grid gap-10 lg:grid-cols-[820px_388px]">
        <div>
          <div class="rounded-lg border border-bloom-line bg-bloom-ivory p-5 shadow-[0_18px_34px_rgba(13,33,28,0.08),0_4px_8px_rgba(13,33,28,0.04)] md:p-8">
            <h2 class="font-serif-tc text-[22px] font-semibold leading-8 text-bloom-ink">花禮明細</h2>
            <p class="mt-1 text-[13px] leading-[19px] text-bloom-muted">
              共 {{ itemCount }} 件商品，可調整數量或移除花束。
            </p>

            <div class="mt-7 space-y-5">
              <article
                v-for="(item, index) in items"
                :key="item.id"
                class="relative flex min-h-[132px] flex-col items-start gap-5 rounded-lg border border-bloom-line bg-bloom-ivory p-5 shadow-[0_18px_34px_rgba(13,33,28,0.06),0_4px_8px_rgba(13,33,28,0.04)] sm:flex-row sm:items-center sm:gap-6"
              >
                <img
                  :src="imageFor(item.product)"
                  :alt="item.product.name"
                  class="h-[92px] w-[92px] shrink-0 rounded-lg bg-bloom-photo object-cover"
                />
                <div class="min-w-0 flex-1">
                  <h3 class="font-serif-tc text-lg font-semibold leading-[26px] text-bloom-ink">{{ item.product.name }}</h3>
                  <p class="mt-1 text-xs leading-[17px] text-bloom-muted">{{ productSubtitle(item.product, index) }}</p>
                  <span class="mt-3 inline-flex h-[30px] items-center rounded-full bg-bloom-cream px-5 text-xs font-medium text-bloom-green">
                    {{ productChip(index) }}
                  </span>
                </div>

                <div class="flex h-[42px] w-full items-center justify-between rounded-lg border border-bloom-line bg-bloom-cream px-4 text-[13px] font-semibold text-bloom-green sm:w-[110px] sm:shrink-0">
                  <button
                    @click="updateQuantity(item.id, item.quantity - 1)"
                    :disabled="item.quantity <= 1"
                    class="disabled:cursor-not-allowed disabled:opacity-40"
                  >
                    -
                  </button>
                  <span>{{ item.quantity }}</span>
                  <button
                    @click="updateQuantity(item.id, item.quantity + 1)"
                    :disabled="item.quantity >= item.product.stock"
                    class="disabled:cursor-not-allowed disabled:opacity-40"
                  >
                    +
                  </button>
                </div>

                <p class="w-full text-left text-base font-bold leading-[23px] text-bloom-brass sm:w-[118px] sm:shrink-0 sm:text-right">
                  NT$ {{ (item.product.price * item.quantity).toLocaleString() }}
                </p>

                <button
                  @click="confirmDelete(item.id)"
                  class="absolute -right-3 -top-3 flex h-[34px] w-[34px] items-center justify-center rounded-full border border-bloom-line bg-bloom-ivory text-base font-semibold text-bloom-green hover:text-red-600"
                  aria-label="移除商品"
                >
                  X
                </button>
              </article>
            </div>
          </div>

          <div class="mt-8 hidden rounded-lg border border-bloom-line bg-bloom-ivory px-8 py-5">
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
              <div>
                <h2 class="font-serif-tc text-base font-semibold text-bloom-ink">花禮卡片留言</h2>
                <p class="mt-2 text-sm leading-5 text-bloom-muted">可於結帳頁補上卡片祝福文字。</p>
              </div>
              <a href="/checkout" class="inline-flex h-11 items-center justify-center rounded-lg border border-bloom-line bg-bloom-cream px-8 text-[13px] font-semibold text-bloom-green hover:text-bloom-brass">
                新增留言
              </a>
            </div>
          </div>
        </div>

        <aside class="rounded-lg bg-bloom-green p-6 text-bloom-ivory shadow-[0_18px_34px_rgba(13,33,28,0.10),0_4px_8px_rgba(13,33,28,0.04)] md:p-9 lg:sticky lg:top-32 lg:h-[604px]">
          <p class="text-xs font-semibold uppercase text-bloom-brass">Order Summary</p>
          <h2 class="font-serif-tc mt-3 text-[28px] font-bold leading-[41px]">訂單摘要</h2>
          <p class="mt-2 text-[13px] leading-[19px] text-bloom-sage">
            花漾生活將保留花材與配送時段，確認後前往結帳。
          </p>

          <div class="mt-7 h-px bg-bloom-sage"></div>

          <div class="mt-8 space-y-7 text-sm">
            <div class="flex justify-between">
              <span>商品小計</span>
              <span class="font-medium">NT$ {{ total.toLocaleString() }}</span>
            </div>
            <div class="flex justify-between">
              <span>配送運費</span>
              <span class="font-medium">{{ shippingFee === 0 ? 'NT$0' : 'NT$' + shippingFee.toLocaleString() }}</span>
            </div>
            <div class="flex justify-between">
              <span>夏季花束優惠</span>
              <span class="font-semibold text-bloom-brass">{{ discount > 0 ? '- NT$' + discount.toLocaleString() : 'NT$0' }}</span>
            </div>
          </div>

          <div class="mt-10 h-px bg-bloom-sage"></div>

          <div class="mt-8 flex items-center justify-between">
            <span class="text-lg font-bold">總計</span>
            <span class="font-serif-tc text-[28px] font-bold leading-[41px] text-bloom-brass">NT$ {{ finalTotal.toLocaleString() }}</span>
          </div>

          <button
            @click="goCheckout"
            class="mt-9 h-14 w-full rounded-lg bg-bloom-brass text-[13px] font-semibold text-bloom-deep hover:bg-[#D4B777]"
          >
            前往結帳
          </button>
          <a href="/#products" class="mt-4 flex h-11 w-full items-center justify-center rounded-lg border border-bloom-line text-[13px] font-semibold text-bloom-ivory hover:text-bloom-brass">
            繼續挑選花束
          </a>
        </aside>
      </div>
    </template>
  </section>

  <div v-if="confirmVisible" class="fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/40" @click="confirmVisible = false"></div>
    <div class="relative mx-4 w-full max-w-sm rounded-lg border border-bloom-line bg-bloom-ivory p-6 shadow-[0_10px_28px_rgba(0,0,0,0.18)] sm:p-7">
      <h3 class="font-serif-tc text-xl font-bold text-bloom-green">確認移除</h3>
      <p class="mt-3 text-sm text-bloom-ink">確定要從購物車中移除這個商品嗎？</p>
      <div class="mt-5 flex gap-6 text-sm font-medium">
        <button @click="confirmVisible = false" class="text-bloom-blush hover:text-bloom-green">取消</button>
        <button @click="handleDelete" class="text-bloom-blush hover:text-red-600">確認移除</button>
      </div>
    </div>
  </div>
</div>
