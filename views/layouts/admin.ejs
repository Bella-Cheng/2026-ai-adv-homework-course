<!DOCTYPE html>
<html lang="zh-TW">
<%- include('../partials/head') %>
<body class="min-h-screen bg-bloom-cream text-bloom-ink">
  <%- include('../partials/admin-header') %>
  <div class="flex min-h-[calc(100vh-110px)] flex-col lg:flex-row">
    <%- include('../partials/admin-sidebar') %>
    <main class="min-w-0 flex-1 bg-bloom-cream px-4 py-8 sm:px-6 md:px-10 lg:px-14 lg:py-10">
      <%- body %>
    </main>
  </div>
  <%- include('../partials/notification') %>

  <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
  <script src="/js/auth.js"></script>
  <script src="/js/api.js"></script>
  <script src="/js/notification.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      if (!Auth.requireAdmin()) return;
      var el = document.getElementById('admin-username');
      if (el) el.textContent = Auth.getUser()?.name || '';
    });
  </script>
  <% if (typeof pageScript !== 'undefined' && pageScript) { %>
  <script src="/js/pages/<%= pageScript %>.js"></script>
  <% } %>
</body>
</html>
